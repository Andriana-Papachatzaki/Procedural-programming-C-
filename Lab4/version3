void save_text(CharNode_ptr * array){
    char name[N];
    CharNode_ptr current_ptr;
    current_ptr=*array;
    printf("Give file name(.txt):");
    scanf("%s",name);
    FILE * writefile;
    writefile = fopen(name, "wt");
    for(;current_ptr!=NULL;){
        fprintf(writefile, "%s ",current_ptr->str);
        current_ptr=current_ptr->node;
    }fclose(writefile);
}


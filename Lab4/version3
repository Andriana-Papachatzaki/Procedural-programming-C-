void input_text(CharNode_ptr *text, int *count){
    FILE *readfile;
    char name[N];
    char *word;
    *count=0;
    CharNode_ptr previous_ptr,current_ptr,mytext;
    printf("Give a .txt file:");
    scanf("%s",name);
    readfile = fopen(name,"r");
    if(!readfile){
        printf("\nError opening the file\n");
        exit(EXIT_FAILURE);
    }
    while(fscanf(readfile,"%s",word=malloc(M*sizeof(char)))!=EOF){
        (*count)++;
        mytext=malloc(sizeof(Node));
        mytext->str=word;
        mytext->node=NULL;
        if(mytext!=NULL){
            previous_ptr=NULL;
            current_ptr=*text;
            while(current_ptr!=NULL){
                previous_ptr=current_ptr;
                current_ptr=current_ptr->node;
            }
            if(previous_ptr==NULL){
                mytext->node=*text;
                *text=mytext;
            }
            else{
                previous_ptr->node=mytext;
                mytext->node=current_ptr;
            }
        }  
    }
    free(word);
    fclose(readfile);
    return;
}

void input_vocabulary(CharNode_ptr *vocab, int *words){
    (*words)=0;
    FILE * readfile;
    readfile = fopen("englishWords.txt","r");
    CharNode_ptr previous_ptr,current_ptr,voc;
    char *WORD;
    if(!readfile){
        printf("\nError opening the file\n");
        exit(EXIT_FAILURE);
    }
    while(fscanf(readfile,"%s",WORD=malloc(M*sizeof(char)))!=EOF){
        (*words)++;
        voc=malloc(sizeof(Node));
        voc->str=WORD;
        voc->node=NULL;
        if(voc!=NULL){
            previous_ptr=NULL;
            current_ptr=*vocab;
            while(current_ptr!=NULL){
                previous_ptr=current_ptr;
                current_ptr=current_ptr->node;
            }
            if(previous_ptr==NULL){
                voc->node=*vocab;
                *vocab=voc;
            }
            else{
                previous_ptr->node=voc;
                voc->node=current_ptr;
            }
        }
    }
    free(WORD);
    printf("vocabulary saved");
    fclose(readfile);
    return;
}


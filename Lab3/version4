#include<stdio.h>
#include<string.h>
#define N 30000
#define M 30
int get_choice(void);
void input_text(char array[N][M]);
void input_vocabulary(char array[N][M]);
void text_correction(char text[N][M], char voc[N][M]);
void save_text(char array[N][M]);
void text_statistics(char array[N][M]);

int main(void){
    int input;
    char words[N][M];
    char vocabulary[N][M];
    printf("0.input text\n1.input vocabulary\n2.text correction\n3.save text\n4.text statistics\n5.exit programm\n");
    for(;(input=get_choice())!=5;){
        switch(input){
            case 0:
            input_text(words);
            break;
            case 1:
            input_vocabulary(vocabulary);
            break;
            case 2:
            text_correction(words,vocabulary);
            break;
            case 3:
            save_text(words);
            break;
            case 4:
            text_statistics(words);
            break;
            default:
            printf("You didn't enter a number!");
        }
        printf("\n\n0.input text\n1.input vocabulary\n2.text correction\n3.save text\n4.text statistics\n5.exit programm\n");
    }
return 0;
}

int get_choice(void){
    int input;
    printf("\nSelect a number:");
    scanf("%d",&input);
    return input;
}

void input_text(char array[N][M]){
    int c=0;
    FILE *readfile;
    char name[N];
    char input[M];
    printf("Give a .txt file:");
    scanf("%s",name);
    readfile = fopen(name,"r");
    if(!readfile){
        printf("\nError opening the file\n");
        return;
    }
    while(fscanf(readfile,"%s",input)!=EOF){
        strcpy(array[c++],input);
        if(c<N){
            for(int i=c;i<N;i++){
                array[i][0]='\0';
            }
        }
        if(c==N)break;
    }fclose(readfile);
}

void input_vocabulary(char array[N][M]){
    int c;
    FILE * readfile;
    char input[M];
    readfile = fopen("englishWords.txt","r");
    if(!readfile){
        printf("\nError opening the file\n");
        return;
    }
    while(fscanf(readfile,"%s",input)!=EOF){
        strcpy(array[c++],input);
        if(c<N){
            for(int i=c;i<N;i++){
                array[i][0]='\0';
            }
        }
        if(c==N)break;
    }
    printf("vocabulary saved");
    fclose(readfile);
}

void text_correction(char text[N][M], char voc[N][M]){
    int i,j;
    int input;
    int choice;
    int result=0;
    for(i=0;i<N;i++){
        for(j=0;j<N;j++){
            int comp=strcmp(text[i],voc[j]);
            if(comp!=0){
                printf("\n\n%s doesn't exist in vocabulary\n",text[i]);
                printf("0.Replace word\n1.Add word in vocabulary\n2.Continue to the next word\n3.Exit\n");
                input=get_choice();
                    switch(input){
                        case 0:
                        printf("Give the word you want to replace with:");
                        scanf("%s",text[i]);
                        for(int x=0;x<N;x++){
                            if(strcmp(text[i],voc[x])==0){
                                result=1;
                                break;
                            }else{
                                result=0;
                            }
                        }if(result!=1){
                            printf("This word isn't in vocabulary\n0.Add to the vocabulary\n1.Continue");
                            scanf("%d",&choice);
                            if(choice==0){
                            for(int x=0;x<N;x++){
                                if(voc[x][0]=='\0'){
                                    strcpy(voc[x],text[i]);
                                    break;
                                }
                            }
                        }
                        }else{
                            printf("This word is in vocabulary");
                        }
                        break;
                        case 1:
                        for(int x=0;x<N;x++){
                            if(voc[x][0]=='\0'){
                                strcpy(voc[x],text[i]);
                                break;
                            }
                        }
                        break;
                        case 2:
                        break;
                        case 3:
                        return;
                }break;
            }
        }
    }
}

void save_text(char array[N][M]){
    int i;
    char name[N];
    printf("Give file name(.txt):");
    scanf("%s",name);
    FILE * writefile;
    writefile = fopen(name, "wt");
    for(i=0;i<N;i++){
        fprintf(writefile, "%s ",array[i]);
    }fclose(writefile);
}

void text_statistics(char array[N][M]){
    int i,j=0;
    int c=0;
    int withoutspaces=0;
    int withspaces=0;
    for(i=0;i<N;i++){
        if(array[i][0]!='\0'){
            c++;
        }
    }printf("number of words:%d\n",c);
    for(i=0;i<c;i++){
        for(j=0;array[i][j]!='\0';j++){
            withoutspaces++;
            withspaces++;
        }withspaces++;
    }printf("Characters without spaces:%d\nCharacters with spaces:%d\n",withoutspaces,withspaces);
    int different=0;
    char state[N];
    for(i=0;i<N;i++){
        state[i]='0';
    }
    for(j = 0; j < c; j++){
        if(state[j]=='0'){
            for(i=j+1; i<c; i++){
                int result=strcmp(array[j],array[i]);
                if(result==0){
                    state[i]='1';
                }
            }
            different++;
        }
    }
    printf("different words:%d",different);
    int times[30]={0};
    for(i=0;i<c;i++){
        int len=strlen(array[i]);
        for(j=0;j<=len;j++){
            if(j==len){
                times[j]++;
            }
        }
    }
    printf("\nnumber of characters\t total words\n");
    for(i=0;i<30;i++){
        printf("%d\t\t\t %d\n",i,times[i]);
        }
    char name[N];
    printf("Give file name to save statistics(.txt):");
    scanf("%s",name);
    FILE * writefile;
    writefile=fopen(name,"wt");
    fprintf(writefile,"number of words:%d\n",c);
    fprintf(writefile,"Characters without spaces:%d\nCharacters with spaces:%d\n",withoutspaces,withspaces);
    fprintf(writefile,"different words:%d",different);
    fprintf(writefile,"\nnumber of characters\t total words\n");
    for(i=0;i<=M;i++){
        fprintf(writefile,"%d\t\t\t %d\n",i,times[i]);
        }
        fclose(writefile);
    printf("Statistics saved succesful");
}
